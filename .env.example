# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APIFY_TOKEN: Required for the Marktplaats Scraper.
# You can get this from your Apify account settings.
APIFY_TOKEN=
APIFY_ACTOR_ID=

# Mollie Betaalprovider (Nieuw)
# Gebruik je test_ of live_ API sleutel van het Mollie dashboard
MOLLIE_API_KEY=

# Gemini
GEMINI_API_KEY=
