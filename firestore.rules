rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Notice: For users, we may allow unverified creation to bootstrap the auth flow or standard OAuth
    function isSignedIn() { return request.auth != null; }

    function isValidGebruiker(data) {
      return data.keys().hasAll(['email', 'uid', 'aanmaakdatum']) 
        && data.email is string && data.email.size() <= 100
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid;
    }

    function isValidAnalyse(data) {
      return data.keys().hasAll(['userId', 'url', 'title', 'price', 'score', 'createdAt'])
        && data.userId is string && data.userId == request.auth.uid
        && data.url is string && data.url.size() <= 1000
        && data.title is string && data.title.size() <= 500
        && data.price is string && data.price.size() <= 100
        && data.score is number
        && data.createdAt is timestamp
        && (!('status' in data) || (data.status is string && data.status.size() <= 100))
        && (!('statusColor' in data) || (data.statusColor is string && data.statusColor.size() <= 100))
        && (!('img' in data) || (data.img is string && data.img.size() <= 1000));
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'ibrahimdiscord675@gmail.com' || 
        request.auth.token.email == 'sblzakelijk@gmail.com' || 
        request.auth.token.email == 'bedrijfsondernemernl1@gmail.com' ||
        request.auth.token.email == 'admin_server_bot@occasionscan.nl'
      );
    }

    function isServerAdmin() {
      return request.auth != null && (
        request.auth.uid == '8fUk6gV6ZuUVQHvsRu5WY8YRWYF2' || 
        request.auth.token.email == 'admin_server_bot@occasionscan.nl'
      );
    }

    // 1. Gebruikers
    match /gebruikers/{userId} {
      allow get, create, update, delete: if isSignedIn() && (userId == request.auth.uid || isAdmin() || isServerAdmin());
      allow list: if isAdmin() || isServerAdmin();
    }

    // 2. Analyses
    match /analyses/{analyseId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isServerAdmin());
      allow create: if true;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isServerAdmin());
      allow update: if isServerAdmin();
    }

    // 3. Rapporten
    match /rapporten/{rapportId} {
      allow get: if true;
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isServerAdmin());
      allow create: if true;
      allow update: if true;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isServerAdmin());
    }

    // 5. Stripe Extension
    match /customers/{uid} {
      allow read: if request.auth.uid == uid;
      
      match /checkout_sessions/{id} {
        allow read, write: if request.auth.uid == uid;
      }
      
      match /subscriptions/{id} {
        allow read: if request.auth.uid == uid;
      }
      
      match /payments/{id} {
        allow read: if request.auth.uid == uid;
      }
    }

    // 6. Limited IPs tracking
    match /limited_ips/{ip} {
      allow read, write: if true; // Server side uses admin or isServerAdmin, but client might check
    }

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
