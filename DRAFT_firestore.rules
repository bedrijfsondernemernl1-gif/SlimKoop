rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }

    function isValidGebruiker(data) {
      return data.keys().hasAll(['email', 'uid', 'aanmaakdatum']) 
        && data.keys().size() == 3
        && data.email is string && data.email.size() <= 100
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.aanmaakdatum is timestamp;
    }

    // 1. Gebruikers
    match /gebruikers/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidGebruiker(incoming()) && incoming().aanmaakdatum == request.time;
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidGebruiker(incoming()) 
        && incoming().uid == existing().uid
        && incoming().aanmaakdatum == existing().aanmaakdatum
        && incoming().diff(existing()).affectedKeys().hasOnly(['email']); 
    }
  }
}
